# ═══════════════════════════════════════════════════════════════
# ENV FILE - Cấu hình môi trường (KHÔNG COMMIT LÊN GIT)
# ═══════════════════════════════════════════════════════════════
# Copy file này thành .env và cập nhật giá trị thật tế

# SQL Server Configuration
SQL_SA_PASSWORD=Admin@123
SQL_ACCEPT_EULA=Y

# .NET Backend Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
DB_CONNECTION_STRING=Server="",1433;Database=UniCheckDB;User Id=sa;Password=password;Encrypt=False;TrustServerCertificate=True;

# Python AI Configuration
PYTHONUNBUFFERED=1
API_HOST=0.0.0.0
API_PORT=8000
