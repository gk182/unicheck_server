<!-- Toast Notification Template -->
<div class="toast align-items-center border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" style="background-color: white; border-radius: var(--radius); overflow: hidden;">
    <div class="d-flex" style="border-left: 4px solid var(--primary);">
        <div class="toast-body d-flex align-items-center" style="color: var(--text-dark); font-weight: 500;">
            <i class="fa fa-check-circle me-3" style="color: var(--primary); font-size: 1.25rem;"></i>
            <span id="toastMessage">Thông báo thành công</span>
        </div>
        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close" style="font-size: 0.8rem;"></button>
    </div>
</div>
