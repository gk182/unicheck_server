<!-- Empty State Component -->
<div class="empty-state text-center py-5">
    <div class="mb-4">
        <i class="fas fa-inbox" style="font-size: 4rem; color: #d4d4d8;"></i>
    </div>
    <h5 class="text-muted mb-2">@ViewBag.Title ?? "Không có dữ liệu"</h5>
    <p class="text-muted small">@ViewBag.Message ?? "Vui lòng thử lại sau"</p>
    @if (!string.IsNullOrEmpty(ViewBag.ActionText))
    {
        <a href="@ViewBag.ActionUrl" class="btn btn-sm btn-primary mt-3">
            @ViewBag.ActionText
        </a>
    }
</div>
