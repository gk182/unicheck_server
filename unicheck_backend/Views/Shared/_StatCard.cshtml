<!-- Stats Card Component -->
@{
    var cardClass = ViewBag.CardClass ?? "primary";
    var icon = ViewBag.Icon ?? "fa-chart-bar";
    var number = ViewBag.Number ?? "0";
    var label = ViewBag.Label ?? "";
    var trend = ViewBag.Trend ?? "";
}

<div class="stat-card card bg-light border-0 rounded-lg shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <p class="text-muted text-sm mb-1">@label</p>
                <h3 class="stat-number text-@cardClass mb-2">@number</h3>
                @if (!string.IsNullOrEmpty(trend))
                {
                    <small class="text-success">
                        <i class="fas fa-arrow-up"></i> @trend
                    </small>
                }
            </div>
            <div class="stat-icon bg-@cardClass text-white rounded-circle">
                <i class="fas @icon"></i>
            </div>
        </div>
    </div>
</div>
