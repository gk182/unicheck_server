@* AttendanceTable.razor - Bảng điểm danh có thể edit inline status *@

<div class="attendance-table-wrapper">
    @if (Rows == null || !Rows.Any())
    {
        <div class="empty-state">
            <i class="fa fa-table fa-3x text-muted mb-3"></i>
            <p class="text-muted">Chưa có dữ liệu điểm danh</p>
        </div>
    }
    else
    {
        <table class="table attendance-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>MSSV</th>
                    <th>Họ tên</th>
                    <th>Giờ vào</th>
                    <th>Khuôn mặt</th>
                    <th>GPS</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Rows.Count; i++)
                {
                    var row = Rows[i];
                    var idx = i + 1;
                    <tr class="@RowClass(row.Status)">
                        <td class="row-num">@idx</td>
                        <td class="student-id-cell">@row.StudentId</td>
                        <td class="student-name-cell">@row.FullName</td>
                        <td class="checkin-time">
                            @(row.CheckInTime ?? "—")
                        </td>
                        <td class="face-cell">
                            @if (row.FaceConfidence.HasValue)
                            {
                                <span class="confidence-badge @(row.FaceConfidence >= 0.8 ? "conf-good" : "conf-warn")">
                                    <i class="fa fa-face-smile me-1"></i>@row.FaceConfidence.Value.ToString("P0")
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="gps-cell">
                            @if (row.CheckInTime != null)
                            {
                                <i class="fa @(row.LocationVerified ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="status-cell">
                            <select class="status-select status-@row.Status.ToLower()"
                                    value="@row.Status"
                                    @onchange="e => HandleChange(row.StudentId, e.Value?.ToString() ?? row.Status)">
                                <option value="PRESENT">✅ Có mặt</option>
                                <option value="LATE">⏰ Đi muộn</option>
                                <option value="ABSENT">❌ Vắng</option>
                                <option value="EXCUSED">📄 Có phép</option>
                            </select>
                        </td>
                        <td class="note-cell">
                            <input type="text" class="note-input" placeholder="Ghi chú..."
                                   value="@row.Note" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public List<AttendanceRowModel>?  Rows            { get; set; }
    [Parameter] public EventCallback<(string, string)> OnStatusChanged { get; set; }

    private string RowClass(string status) => status switch
    {
        "PRESENT" => "row-present",
        "LATE"    => "row-late",
        "ABSENT"  => "row-absent",
        "EXCUSED" => "row-excused",
        _         => ""
    };

    private async Task HandleChange(string studentId, string newStatus)
    {
        await OnStatusChanged.InvokeAsync((studentId, newStatus));
    }
}

