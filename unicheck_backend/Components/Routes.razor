<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <div class="card-panel">
                            <div class="panel-body text-center py-5">
                                <h4 class="mb-3"><i class="fa fa-lock me-2"></i>Không có quyền truy cập</h4>
                                <p class="text-muted mb-3">Bạn không có quyền truy cập trang này.</p>
                                <a href="/login" class="btn btn-primary">Đăng nhập lại</a>
                            </div>
                        </div>
                    </LayoutView>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <unicheck_backend.Components.Pages.NotFound />
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
