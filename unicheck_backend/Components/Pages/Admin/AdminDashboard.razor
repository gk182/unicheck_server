@page "/admin"
@attribute [Authorize(Roles = "ADMIN")]
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS

@layout unicheck_backend.Components.Layout.AdminLayout

<PageTitle>Quản Trị Học Vụ - UniCheck</PageTitle>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_isError ? "alert-danger bg-danger-subtle text-danger" : "alert-success bg-success-subtle text-success") border-0 shadow-sm rounded-3 mb-4 animate__animated animate__fadeInDown" role="alert">
        <i class="fa @(_isError ? "fa-circle-xmark" : "fa-check-circle") me-2"></i> @_message
    </div>
}

<div class="row g-4">
    <!-- LEFT PANEL: ACTION FORMS -->
    <div class="col-12 col-xl-4">
        <!-- Action Tabs -->
        <ul class="nav nav-pills nav-fill bg-white p-2 rounded-4 shadow-sm mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-3 @(_activeActionTab == 1 ? "active fw-bold shadow-sm" : "text-secondary")" @onclick="() => _activeActionTab = 1">
                    <i class="fa fa-layer-group me-1"></i> QL Lớp
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-3 @(_activeActionTab == 2 ? "active fw-bold shadow-sm" : "text-secondary")" @onclick="() => _activeActionTab = 2">
                    <i class="fa fa-calendar-alt me-1"></i> Xếp Lịch
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-3 @(_activeActionTab == 3 ? "active fw-bold shadow-sm" : "text-secondary")" @onclick="() => _activeActionTab = 3">
                    <i class="fa fa-users me-1"></i> Sinh Viên
                </button>
            </li>
        </ul>

        @if (_activeActionTab == 1)
        {
            <div class="admin-card animate__animated animate__fadeIn">
                <h5 class="admin-card-title"><i class="fa fa-plus-circle text-primary"></i> Khởi tạo lớp học phần</h5>
                <div class="mb-3">
                    <label class="admin-form-label">Môn học</label>
                    <select class="form-select admin-form-control" @bind="_createClass.CourseId">
                        <option value="0">-- Chọn môn học --</option>
                        @foreach (var c in _courses)
                        {
                            <option value="@c.CourseId">@c.CourseCode - @c.CourseName</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="admin-form-label">Giảng viên phụ trách</label>
                    <select class="form-select admin-form-control" @bind="_createClass.LecturerId">
                        <option value="0">-- Chọn giảng viên --</option>
                        @foreach (var l in _lecturers)
                        {
                            <option value="@l.LecturerId">@l.FullName (@l.Email)</option>
                        }
                    </select>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-4">
                        <label class="admin-form-label">Học kỳ</label>
                        <select class="form-select admin-form-control" @bind="_createClass.Semester">
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">Hè</option>
                        </select>
                    </div>
                    <div class="col-8">
                        <label class="admin-form-label">Năm học</label>
                        <input class="form-control admin-form-control" @bind="_createClass.AcademicYear" placeholder="Ví dụ: 2025-2026" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="admin-form-label">Mã nhóm</label>
                    <input class="form-control admin-form-control" @bind="_createClass.GroupCode" placeholder="Ví dụ: N01" />
                </div>
                <button class="btn admin-btn admin-btn-primary w-100" @onclick="CreateClassAsync">
                    <i class="fa fa-save me-1"></i> Tạo lớp học phần
                </button>
            </div>

            <div class="admin-card animate__animated animate__fadeIn">
                <h5 class="admin-card-title"><i class="fa fa-user-pen text-warning"></i> Điều chỉnh giảng viên</h5>
                <div class="mb-3">
                    <label class="admin-form-label">Lớp học phần</label>
                    <select class="form-select admin-form-control" @bind="_assignLecturer.ClassId">
                        <option value="0">-- Chọn lớp --</option>
                        @foreach (var c in _classes)
                        {
                            <option value="@c.ClassId">@c.CourseCode - @c.GroupCode (@c.LecturerName)</option>
                        }
                    </select>
                </div>
                <div class="mb-4">
                    <label class="admin-form-label">Giảng viên mới</label>
                    <select class="form-select admin-form-control" @bind="_assignLecturer.LecturerId">
                        <option value="0">-- Chọn giảng viên --</option>
                        @foreach (var l in _lecturers)
                        {
                            <option value="@l.LecturerId">@l.FullName</option>
                        }
                    </select>
                </div>
                <button class="btn admin-btn btn-warning w-100 text-white fw-medium" @onclick="AssignLecturerAsync">
                    <i class="fa fa-exchange-alt me-1"></i> Cập nhật giảng viên
                </button>
            </div>
        }
        else if (_activeActionTab == 2)
        {
            <div class="admin-card animate__animated animate__fadeIn">
                <h5 class="admin-card-title"><i class="fa fa-calendar-pen text-info"></i> Sắp xếp lịch học</h5>
                <div class="mb-3">
                    <label class="admin-form-label">Buổi học (Chọn để sửa)</label>
                    <select class="form-select admin-form-control" @bind="_editSchedule.ScheduleId" @bind:after="OnScheduleChangedAsync">
                        <option value="0">-- Chọn buổi học --</option>
                        @foreach (var s in _schedules)
                        {
                            <option value="@s.ScheduleId">@s.CourseCode/@s.GroupCode - @s.Date.ToString("dd/MM/yyyy")</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="admin-form-label">Ngày học</label>
                    <input type="text" class="form-control admin-form-control" @bind="_editSchedule.DateText" placeholder="yyyy-MM-dd" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="admin-form-label">Bắt đầu</label>
                        <input type="text" class="form-control admin-form-control" @bind="_editSchedule.StartText" placeholder="HH:mm" />
                    </div>
                    <div class="col-6">
                        <label class="admin-form-label">Kết thúc</label>
                        <input type="text" class="form-control admin-form-control" @bind="_editSchedule.EndText" placeholder="HH:mm" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="admin-form-label">Phòng học</label>
                    <select class="form-select admin-form-control" @bind="_editSchedule.RoomId">
                        <option value="0">-- Chọn phòng --</option>
                        @foreach (var room in _rooms)
                        {
                            <option value="@room.RoomId">@room.RoomName</option>
                        }
                    </select>
                </div>
                <button class="btn admin-btn btn-info w-100 text-white fw-medium" @onclick="UpdateScheduleAsync">
                    <i class="fa fa-check me-1"></i> Lưu thay đổi lịch
                </button>
            </div>
        }
        else if (_activeActionTab == 3)
        {
            <div class="admin-card animate__animated animate__fadeIn">
                <h5 class="admin-card-title"><i class="fa fa-user-plus text-success"></i> Thêm sinh viên vào lớp</h5>
                <div class="mb-3">
                    <label class="admin-form-label">Lớp học phần</label>
                    <select class="form-select admin-form-control" @bind="_enroll.ClassId">
                        <option value="0">-- Chọn lớp --</option>
                        @foreach (var c in _classes)
                        {
                            <option value="@c.ClassId">@c.CourseCode - @c.GroupCode</option>
                        }
                    </select>
                </div>
                <div class="mb-4">
                    <label class="admin-form-label">Danh sách MSSV (cách nhau bởi dấu phẩy hoặc xuống dòng)</label>
                    <textarea class="form-control admin-form-control" rows="4" @bind="_enroll.StudentIdsRaw" placeholder="3120222001&#10;3120222002"></textarea>
                </div>
                <button class="btn admin-btn btn-success w-100 mb-4" @onclick="EnrollStudentsAsync">
                    <i class="fa fa-user-check me-1"></i> Thêm sinh viên
                </button>
                
                <hr class="text-secondary" />
                
                <h6 class="mt-3 mb-3 fw-bold text-secondary"><i class="fa fa-file-csv me-2"></i>Hoặc nhập từ CSV</h6>
                <div class="mb-3">
                    <textarea class="form-control admin-form-control" rows="3" @bind="_enroll.CsvContent" placeholder="Chỉ cần dán nội dung CSV (cột đầu tiên là MSSV)"></textarea>
                </div>
                <button class="btn admin-btn btn-outline-secondary w-100" @onclick="ImportCsvAsync">
                    <i class="fa fa-upload me-1"></i> Import CSV
                </button>
            </div>
        }
    </div>

    <!-- RIGHT PANEL: DATA TABLES -->
    <div class="col-12 col-xl-8">
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="admin-card p-3 mb-0 text-center">
                    <div class="text-primary fs-3 mb-1"><i class="fa fa-chalkboard"></i></div>
                    <div class="fw-bold fs-4 text-slate-800">@_classes.Count</div>
                    <div class="text-slate-500 small">Lớp học phần</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="admin-card p-3 mb-0 text-center">
                    <div class="text-success fs-3 mb-1"><i class="fa fa-user-tie"></i></div>
                    <div class="fw-bold fs-4 text-slate-800">@_lecturers.Count</div>
                    <div class="text-slate-500 small">Giảng viên</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="admin-card p-3 mb-0 text-center">
                    <div class="text-warning fs-3 mb-1"><i class="fa fa-user-graduate"></i></div>
                    <div class="fw-bold fs-4 text-slate-800">@_studentCount</div>
                    <div class="text-slate-500 small">Sinh viên</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="admin-card p-3 mb-0 text-center">
                    <div class="text-info fs-3 mb-1"><i class="fa fa-door-open"></i></div>
                    <div class="fw-bold fs-4 text-slate-800">@_rooms.Count</div>
                    <div class="text-slate-500 small">Phòng học</div>
                </div>
            </div>
        </div>

        <div class="admin-card">
            <!-- Tabs cho Bảng Dữ Liệu -->
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(_activeTableTab == 1 ? "active fw-bold text-primary" : "text-secondary")" @onclick="() => _activeTableTab = 1">
                        <i class="fa fa-list me-1"></i> Danh sách Lớp Học
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(_activeTableTab == 2 ? "active fw-bold text-primary" : "text-secondary")" @onclick="() => _activeTableTab = 2">
                        <i class="fa fa-calendar-alt me-1"></i> Danh sách Lịch Dạy
                    </button>
                </li>
            </ul>

            <div class="table-responsive">
                @if (_activeTableTab == 1)
                {
                    <table class="table table-hover align-middle">
                        <thead class="table-light text-secondary font-sm">
                            <tr>
                                <th>ID</th>
                                <th>Môn học</th>
                                <th>Nhóm</th>
                                <th>Học kỳ</th>
                                <th>Giảng viên</th>
                                <th>SV</th>
                                <th>Buổi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _classes)
                            {
                                <tr>
                                    <td class="fw-medium">#@c.ClassId</td>
                                    <td>
                                        <div class="fw-bold text-slate-800">@c.CourseName</div>
                                        <div class="text-slate-500 small">@c.CourseCode</div>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@c.GroupCode</span></td>
                                    <td>HK @c.Semester<br><span class="text-slate-500 small">@c.AcademicYear</span></td>
                                    <td>@c.LecturerName</td>
                                    <td><span class="badge bg-success-subtle text-success">@c.EnrollmentCount</span></td>
                                    <td><span class="badge bg-info-subtle text-info">@c.ScheduleCount</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (_activeTableTab == 2)
                {
                    <div class="d-flex justify-content-end mb-3">
                        <select class="form-select form-select-sm" style="max-width: 300px" @bind="_scheduleFilterClassId" @bind:after="OnScheduleFilterChangedAsync">
                            <option value="0">Tất cả lớp học phần</option>
                            @foreach (var c in _classes)
                            {
                                <option value="@c.ClassId">@c.CourseCode - @c.GroupCode</option>
                            }
                        </select>
                    </div>
                    <table class="table table-hover align-middle">
                        <thead class="table-light text-secondary font-sm">
                            <tr>
                                <th>Lớp/Nhóm</th>
                                <th>Ngày</th>
                                <th>Giờ học</th>
                                <th>Phòng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _schedules)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-slate-800">@s.CourseCode</div>
                                        <div class="text-slate-500 small">Nhóm @s.GroupCode</div>
                                    </td>
                                    <td class="fw-medium">@s.Date.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")</span>
                                    </td>
                                    <td>@s.RoomName</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new() { PropertyNameCaseInsensitive = true };

    private string _message = string.Empty;
    private bool _isError;

    private int _activeActionTab = 1;
    private int _activeTableTab = 1;

    private int _studentCount;
    private int _scheduleFilterClassId;

    private List<CourseOption> _courses = new();
    private List<LecturerOption> _lecturers = new();
    private List<RoomOption> _rooms = new();
    private List<ClassRow> _classes = new();
    private List<ScheduleRow> _schedules = new();

    private readonly CreateClassModel _createClass = new();
    private readonly AssignLecturerModel _assignLecturer = new();
    private readonly UpdateScheduleModel _editSchedule = new();
    private readonly EnrollStudentsModel _enroll = new();

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ReloadAsync();
        StateHasChanged();
    }

    private async Task ReloadAsync()
    {
        var metadata = await ApiGetAsync<MetadataResponse>("/api/admin/metadata");
        if (!metadata.Ok)
        {
            ShowError(metadata.Error);
            return;
        }

        _courses = metadata.Data?.Courses ?? new();
        _lecturers = metadata.Data?.Lecturers ?? new();
        _rooms = metadata.Data?.Rooms ?? new();
        _studentCount = metadata.Data?.StudentCount ?? 0;

        var classes = await ApiGetAsync<List<ClassRow>>("/api/admin/classes");
        if (!classes.Ok)
        {
            ShowError(classes.Error);
            return;
        }

        _classes = classes.Data ?? new();

        var schedulePath = _scheduleFilterClassId > 0 ? $"/api/admin/schedules?classId={_scheduleFilterClassId}" : "/api/admin/schedules";
        var schedules = await ApiGetAsync<List<ScheduleRow>>(schedulePath);
        if (!schedules.Ok)
        {
            ShowError(schedules.Error);
            return;
        }

        _schedules = schedules.Data ?? new();
    }

    private async Task CreateClassAsync()
    {
        if (_createClass.CourseId <= 0 || _createClass.LecturerId <= 0 || string.IsNullOrWhiteSpace(_createClass.AcademicYear) || string.IsNullOrWhiteSpace(_createClass.GroupCode))
        {
            ShowError("Vui long nhap day du thong tin tao lop.");
            return;
        }

        var payload = new
        {
            _createClass.CourseId,
            _createClass.LecturerId,
            _createClass.Semester,
            AcademicYear = _createClass.AcademicYear.Trim(),
            GroupCode = _createClass.GroupCode.Trim()
        };

        var result = await ApiPostAsync<JsonElement>("/api/admin/classes", payload);
        if (!result.Ok)
        {
            ShowError(result.Error);
            return;
        }

        ShowSuccess("Tao lop hoc phan thanh cong.");
        await ReloadAsync();
    }

    private async Task AssignLecturerAsync()
    {
        if (_assignLecturer.ClassId <= 0 || _assignLecturer.LecturerId <= 0)
        {
            ShowError("Vui long chon lop va giang vien.");
            return;
        }

        var payload = new { _assignLecturer.LecturerId };
        var result = await ApiPutAsync<JsonElement>($"/api/admin/classes/{_assignLecturer.ClassId}/lecturer", payload);
        if (!result.Ok)
        {
            ShowError(result.Error);
            return;
        }

        ShowSuccess("Cap nhat giang vien thanh cong.");
        await ReloadAsync();
    }

    private Task OnScheduleChangedAsync()
    {
        var selected = _schedules.FirstOrDefault(s => s.ScheduleId == _editSchedule.ScheduleId);
        if (selected is null)
        {
            return Task.CompletedTask;
        }

        _editSchedule.DateText = selected.Date.ToString("yyyy-MM-dd");
        _editSchedule.StartText = selected.StartTime.ToString(@"hh\:mm");
        _editSchedule.EndText = selected.EndTime.ToString(@"hh\:mm");
        _editSchedule.RoomId = selected.RoomId;

        return Task.CompletedTask;
    }

    private async Task UpdateScheduleAsync()
    {
        if (_editSchedule.ScheduleId <= 0 || _editSchedule.RoomId <= 0 || string.IsNullOrWhiteSpace(_editSchedule.DateText) || string.IsNullOrWhiteSpace(_editSchedule.StartText) || string.IsNullOrWhiteSpace(_editSchedule.EndText))
        {
            ShowError("Vui long nhap du thong tin lich hoc.");
            return;
        }

        if (!DateTime.TryParse(_editSchedule.DateText, out var date)
            || !TimeSpan.TryParse(_editSchedule.StartText, out var start)
            || !TimeSpan.TryParse(_editSchedule.EndText, out var end))
        {
            ShowError("Dinh dang ngay/gio khong hop le.");
            return;
        }

        var payload = new
        {
            Date = date,
            StartTime = start,
            EndTime = end,
            RoomId = _editSchedule.RoomId
        };

        var result = await ApiPutAsync<JsonElement>($"/api/admin/schedules/{_editSchedule.ScheduleId}", payload);
        if (!result.Ok)
        {
            ShowError(result.Error);
            return;
        }

        ShowSuccess("Cap nhat lich hoc thanh cong.");
        await ReloadAsync();
    }

    private async Task EnrollStudentsAsync()
    {
        if (_enroll.ClassId <= 0 || string.IsNullOrWhiteSpace(_enroll.StudentIdsRaw))
        {
            ShowError("Vui long chon lop va nhap danh sach MSSV.");
            return;
        }

        var studentIds = _enroll.StudentIdsRaw
            .Split(new[] { ',', '\n', '\r', ';', ' ' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .Distinct()
            .ToList();

        if (studentIds.Count == 0)
        {
            ShowError("Danh sach MSSV khong hop le.");
            return;
        }

        var payload = new
        {
            _enroll.ClassId,
            StudentIds = studentIds
        };

        var result = await ApiPostAsync<EnrollmentResult>("/api/admin/enrollments", payload);
        if (!result.Ok)
        {
            ShowError(result.Error);
            return;
        }

        ShowSuccess(BuildEnrollmentMessage(result.Data));
        await ReloadAsync();
    }

    private async Task ImportCsvAsync()
    {
        if (_enroll.ClassId <= 0 || string.IsNullOrWhiteSpace(_enroll.CsvContent))
        {
            ShowError("Vui long chon lop va nhap noi dung CSV.");
            return;
        }

        var payload = new
        {
            _enroll.ClassId,
            CsvContent = _enroll.CsvContent
        };

        var result = await ApiPostAsync<EnrollmentResult>("/api/admin/enrollments/import-csv", payload);
        if (!result.Ok)
        {
            ShowError(result.Error);
            return;
        }

        ShowSuccess(BuildEnrollmentMessage(result.Data));
        await ReloadAsync();
    }

    private async Task OnScheduleFilterChangedAsync()
    {
        await ReloadAsync();
    }

    private static string BuildEnrollmentMessage(EnrollmentResult? data)
    {
        if (data is null)
        {
            return "Thao tac thanh cong.";
        }

        var msg = $"Them thanh cong {data.SuccessCount} sinh vien";
        if (data.SkippedCount > 0)
        {
            msg += $", bo qua {data.SkippedCount} da ton tai";
        }
        if (data.FailedCount > 0)
        {
            msg += $", khong tim thay {data.FailedCount}";
        }

        return msg + ".";
    }

    private void ShowSuccess(string message)
    {
        _message = message;
        _isError = false;
    }

    private void ShowError(string message)
    {
        _message = message;
        _isError = true;
    }

    private async Task<ApiEnvelope<T>> ApiGetAsync<T>(string path)
    {
        var raw = await JS.InvokeAsync<string>("adminApi.get", path);
        return DeserializeEnvelope<T>(raw);
    }

    private async Task<ApiEnvelope<T>> ApiPostAsync<T>(string path, object payload)
    {
        var raw = await JS.InvokeAsync<string>("adminApi.post", path, payload);
        return DeserializeEnvelope<T>(raw);
    }

    private async Task<ApiEnvelope<T>> ApiPutAsync<T>(string path, object payload)
    {
        var raw = await JS.InvokeAsync<string>("adminApi.put", path, payload);
        return DeserializeEnvelope<T>(raw);
    }

    private static ApiEnvelope<T> DeserializeEnvelope<T>(string raw)
    {
        var result = JsonSerializer.Deserialize<ApiEnvelope<T>>(raw, JsonOptions);
        if (result is null)
        {
            return new ApiEnvelope<T>
            {
                Ok = false,
                Error = "Khong doc duoc du lieu tu API."
            };
        }

        return result;
    }

    private class ApiEnvelope<T>
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public T? Data { get; set; }
        public string Error { get; set; } = string.Empty;
    }

    private class MetadataResponse
    {
        public List<CourseOption> Courses { get; set; } = new();
        public List<LecturerOption> Lecturers { get; set; } = new();
        public List<RoomOption> Rooms { get; set; } = new();
        public int StudentCount { get; set; }
    }

    private class CourseOption
    {
        public int CourseId { get; set; }
        public string CourseCode { get; set; } = string.Empty;
        public string CourseName { get; set; } = string.Empty;
    }

    private class LecturerOption
    {
        public int LecturerId { get; set; }
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }

    private class RoomOption
    {
        public int RoomId { get; set; }
        public string RoomName { get; set; } = string.Empty;
    }

    private class ClassRow
    {
        public int ClassId { get; set; }
        public int CourseId { get; set; }
        public string CourseCode { get; set; } = string.Empty;
        public string CourseName { get; set; } = string.Empty;
        public string GroupCode { get; set; } = string.Empty;
