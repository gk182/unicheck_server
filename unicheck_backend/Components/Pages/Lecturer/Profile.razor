@page "/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using unicheck_backend.Services
@using unicheck_backend.Data
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject AuthService AuthService

<PageTitle>Hồ Sơ — UniCheck</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title-text">
            <i class="fa fa-user-circle me-2"></i>Hồ Sơ Giảng Viên
        </h2>
        <p class="page-subtitle">Thông tin cá nhân và bảo mật tài khoản</p>
    </div>
</div>

<div class="profile-layout">
    <!-- LEFT: Avatar + Basic Info -->
    <div class="profile-sidebar-card">
        <div class="profile-avatar">
            <i class="fa fa-user-tie"></i>
        </div>
        <h5 class="profile-name">@_lecturer.FullName</h5>
        <p class="profile-dept">@_lecturer.Department</p>
        <div class="profile-badges">
            <span class="badge badge-info">Giảng viên</span>
            <span class="badge badge-success">Đang hoạt động</span>
        </div>
        <hr class="profile-divider" />
        <div class="profile-stats">
            <div class="profile-stat">
                <span class="stat-val">@_courseCount</span>
                <span class="stat-lbl">Lớp học phần</span>
            </div>
            <div class="profile-stat">
                <span class="stat-val">@_studentCount</span>
                <span class="stat-lbl">Sinh viên</span>
            </div>
        </div>
    </div>

    <!-- RIGHT: Forms -->
    <div class="profile-forms">
        <!-- Personal Info -->
        <div class="card-panel mb-4">
            <div class="panel-header">
                <h5 class="panel-title"><i class="fa fa-id-card me-2"></i>Thông Tin Cá Nhân</h5>
            </div>
            <div class="panel-body">
                <div class="info-grid">
                    <div class="info-row">
                        <label class="info-label">Họ và tên</label>
                        <span class="info-value">@_lecturer.FullName</span>
                    </div>
                    <div class="info-row">
                        <label class="info-label">Mã giảng viên</label>
                        <span class="info-value font-mono">@_lecturer.LecturerId</span>
                    </div>
                    <div class="info-row">
                        <label class="info-label">Khoa / Bộ môn</label>
                        <span class="info-value">@_lecturer.Department</span>
                    </div>
                    <div class="info-row">
                        <label class="info-label">Email</label>
                        <span class="info-value">@_lecturer.Email</span>
                    </div>
                    <div class="info-row">
                        <label class="info-label">Số điện thoại</label>
                        <span class="info-value">@_lecturer.Phone</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Change Password -->
        <div class="card-panel">
            <div class="panel-header">
                <h5 class="panel-title"><i class="fa fa-lock me-2"></i>Đổi Mật Khẩu</h5>
            </div>
            <div class="panel-body">
                @if (_pwSuccess)
                {
                    <div class="alert alert-success d-flex align-items-center">
                        <i class="fa fa-check-circle me-2"></i>
                        Đổi mật khẩu thành công!
                    </div>
                }
                @if (!string.IsNullOrEmpty(_pwError))
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="fa fa-exclamation-circle me-2"></i>@_pwError
                    </div>
                }
                <div class="pw-form">
                    <div class="form-group mb-3">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" class="form-control" @bind="_currentPw"
                               placeholder="Nhập mật khẩu hiện tại" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" class="form-control" @bind="_newPw"
                               placeholder="Ít nhất 8 ký tự" />
                    </div>
                    <div class="form-group mb-4">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <input type="password" class="form-control" @bind="_confirmPw"
                               placeholder="Nhập lại mật khẩu mới" />
                    </div>
                    <button class="btn btn-primary" @onclick="ChangePassword">
                        <i class="fa fa-key me-2"></i>Đổi mật khẩu
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _pwSuccess  = false;
    private string _pwError  = "";
    private string _currentPw = "";
    private string _newPw     = "";
    private string _confirmPw = "";

    private int _userId;
    private int _courseCount = 0;
    private int _studentCount = 0;

    private LecturerProfile _lecturer = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out var userId))
            {
                _userId = userId;

                using var scope = ScopeFactory.CreateScope();
                var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

                var lecturerInfo = await db.Lecturers
                    .FirstOrDefaultAsync(l => l.UserId == userId);

                if (lecturerInfo != null)
                {
                    _lecturer.LecturerId = lecturerInfo.LecturerId.ToString();
                    _lecturer.FullName = lecturerInfo.FullName;
                    _lecturer.Department = lecturerInfo.Department ?? "Chưa có khoa";
                    _lecturer.Email = lecturerInfo.Email;
                    _lecturer.Phone = "Chưa cập nhật"; // No Phone property in DB Lecturer

                    // Lấy số lượng lớp học phần
                    _courseCount = await db.CourseClasses.CountAsync(c => c.LecturerId == lecturerInfo.LecturerId);

                    // Lấy số lượng sinh viên trong tất cả các lớp của giảng viên
                    _studentCount = await db.Enrollments
                        .Include(e => e.CourseClass)
                        .Where(e => e.CourseClass != null && e.CourseClass.LecturerId == lecturerInfo.LecturerId)
                        .Select(e => e.StudentId)
                        .Distinct()
                        .CountAsync();
                }
            }
        }
    }

    private async Task ChangePassword()
    {
        _pwError   = "";
        _pwSuccess = false;

        if (string.IsNullOrWhiteSpace(_currentPw))
        { 
            _pwError = "Vui lòng nhập mật khẩu hiện tại."; 
            return; 
        }
        if (string.IsNullOrWhiteSpace(_newPw) || _newPw.Length < 8)
        { 
            _pwError = "Mật khẩu mới phải có ít nhất 8 ký tự."; 
            return; 
        }
        if (_newPw != _confirmPw)
        { 
            _pwError = "Mật khẩu xác nhận không khớp."; 
            return; 
        }

        bool result = await AuthService.ChangePasswordAsync(_userId, _currentPw, _newPw);
        if (result)
        {
            _pwSuccess = true;
            _currentPw = _newPw = _confirmPw = "";
        }
        else
        {
            _pwError = "Mật khẩu hiện tại không đúng hoặc có lỗi xảy ra.";
        }
    }

    private class LecturerProfile
    {
        public string LecturerId { get; set; } = "";
        public string FullName   { get; set; } = "";
        public string Department { get; set; } = "";
        public string Email      { get; set; } = "";
        public string Phone      { get; set; } = "";
    }
}
