@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout unicheck_backend.Components.Pages.Auth.AuthLayout
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Đăng nhập — UniCheck</PageTitle>

<div class="login-page">
    <!-- Left Form Section -->
    <div class="login-left">
        <div class="login-card">
            <!-- Brand -->
            <div class="login-header text-start mb-4">
                <h2 class="fw-bold mb-2" style="font-size: 1.75rem; color: #111827;">Đăng nhập tài khoản</h2>
                <p style="color: #6B7280; font-size: 0.95rem;">Nhập thông tin bên dưới để truy cập vào hệ thống</p>
            </div>

            <!-- Visible UI Form -->
            <div class="login-form">
                <div class="form-group mb-4">
                    <label class="form-label fw-semibold" style="color: #374151; font-size: 0.9rem; margin-bottom: 0.5rem;">
                        Tên đăng nhập
                    </label>
                    <input @bind="_username"
                           type="text"
                           class="form-control modern-input"
                           placeholder="Nhập tên đăng nhập..."
                           @onkeyup="@(async e => { if(e.Key == "Enter") await ProcessLogin(); })"
                           required autofocus />
                </div>

                <div class="form-group mb-4">
                    <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.5rem;">
                        <label class="form-label fw-semibold mb-0" style="color: #374151; font-size: 0.9rem;">
                            Mật khẩu
                        </label>
                        <a href="#" class="text-primary text-decoration-none" style="font-size: 0.85rem; font-weight: 500;">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <div class="input-group">
                        <input @bind="_password"
                               type="password"
                               id="passwordInput"
                               class="form-control modern-input"
                               placeholder="Nhập mật khẩu..."
                               @onkeyup="@(async e => { if(e.Key == "Enter") await ProcessLogin(); })"
                               required />
                        <button type="button" class="btn btn-outline-secondary border-start-0"
                                onclick="togglePassword()" style="border-radius: 0 8px 8px 0; border-color: #D1D5DB; background: white;">
                            <i class="fa fa-eye" id="eyeIcon" style="color: #6B7280;"></i>
                        </button>
                    </div>
                </div>

                <button type="button" class="btn modern-btn-login w-100 mb-4" @onclick="ProcessLogin" disabled="@_isProcessing">
                    @if (_isProcessing)
                    {
                        <i class="fa fa-spinner fa-spin me-2"></i><span>Đang kiểm tra...</span>
                    }
                    else
                    {
                        <span>Đăng nhập</span>
                    }
                </button>

                <!-- Footer -->
                <div class="text-center" style="font-size: 0.9rem; color: #6B7280;">
                    Bạn chưa có tài khoản? <a href="#" class="text-primary fw-medium text-decoration-none">Liên hệ ban giám hiệu</a>
                </div>
            </div>

            <!-- Hidden REAL Form for Cookie SignIn -->
            <form id="hidden-login-form" method="post" action="/Auth/Login" style="display:none">
                <input name="Username" type="hidden" />
                <input name="Password" type="hidden" />
                <input name="ReturnUrl" type="hidden" value="/dashboard" />
            </form>
        </div>
    </div>

    <!-- Right Image Section -->
    <div class="login-right">
        <div class="login-right-content">
            <h1 class="login-right-title">UniCheck Dashboard</h1>
            <p class="login-right-desc">Hệ thống quản lý điểm danh sinh viên thông minh và hiện đại dành cho giảng viên.</p>
        </div>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private bool _isProcessing = false;

    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private unicheck_backend.Services.AuthService AuthService { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/dashboard", true);
        }
    }

    private async Task ProcessLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            await JSRuntime.InvokeVoidAsync("showErrorDialog", "Vui lòng nhập đầy đủ thông tin.");
            return;
        }

        _isProcessing = true;
        try
        {
            // Bước 1: Kiểm tra thông tin thật qua AuthService (C#)
            var user = await AuthService.AuthenticateAsync(_username, _password);

            if (user == null)
            {
                await JSRuntime.InvokeVoidAsync("showErrorDialog", "Tên đăng nhập hoặc mật khẩu không đúng.");
                return;
            }

            // Cho phép Lecturer và Admin vào Web
            if (user.Role != unicheck_backend.Models.Enums.UserRole.LECTURER
                && user.Role != unicheck_backend.Models.Enums.UserRole.ADMIN)
            {
                await JSRuntime.InvokeVoidAsync("showErrorDialog", "Bạn không đủ quyền đăng nhập trang web.");
                return;
            }

            // Bước 2: Nếu ổn, gọi JS để submit form ẩn (thực hiện HttpContext.SignInAsync)
            await JSRuntime.InvokeVoidAsync("submitHiddenForm", _username, _password);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("showErrorDialog", "Có lỗi hệ thống: " + ex.Message);
        }
        finally
        {
            _isProcessing = false;
        }
    }
}


